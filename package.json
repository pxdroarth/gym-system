{
  "name": "backend-academia",
  "version": "1.0.0",
  "description": "API Node.js Express para academia",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "backend": "node backend/server.js",
    "frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "e2e": "powershell -ExecutionPolicy Bypass -File tests/scripts/e2e-playwright.ps1",
    "e2e:headed": "powershell -ExecutionPolicy Bypass -File tests/scripts/e2e-playwright.ps1 -Headed",
    "e2e:auth": "powershell -ExecutionPolicy Bypass -File tests/scripts/e2e-playwright.ps1 tests/e2e/playwright/auth.spec.js",
    "e2e:auth:headed": "powershell -ExecutionPolicy Bypass -File tests/scripts/e2e-playwright.ps1 -Headed tests/e2e/playwright/auth.spec.js"
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=9"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.0",
    "mysql2": "^3.14.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
