@startuml
title Estados de Mensalidade
skinparam shadowing false

[*] --> em_aberto : criar mensalidade

em_aberto --> parcial : pagamento parcial
em_aberto --> pago : pagamento integral
em_aberto --> vencido : vencimento ultrapassado
em_aberto --> cancelado : cancelamento autorizado
em_aberto --> bloqueada_por_fechamento : fechamento mensal

parcial --> pago : quitar saldo
parcial --> vencido : saldo pendente após vencimento
parcial --> cancelado : cancelamento autorizado
parcial --> bloqueada_por_fechamento : fechamento mensal

vencido --> parcial : pagamento parcial
vencido --> pago : pagamento integral
vencido --> em_reversao_controlada : reversão controlada

pago --> em_reversao_controlada : estorno/reversão
pago --> bloqueada_por_fechamento : fechamento mensal

bloqueada_por_fechamento --> em_reversao_controlada : reabertura + reversão autorizada
em_reversao_controlada --> em_aberto : lançamento inverso aprovado
em_reversao_controlada --> cancelado : reversão finalizada

cancelado --> [*]
pago --> [*]

note right of bloqueada_por_fechamento
Cobertura de bloqueio por fechamento
está documentada como parcial até validação
de todas as operações sensíveis.
end note
@enduml
