@startuml
title Rotina Operacional — Atendimento Diário
skinparam shadowing false

start
:Login do usuário interno;
:Validar sessão opaca;
if (Sessão válida?) then (sim)
  :Selecionar Unidade operacional;
  :Consultar aluno;
  :Verificar status cadastral e operacional;
  :Verificar mensalidade/vínculos;
  if (Há pendência de pagamento?) then (sim)
    if (Perfil pode registrar pagamento?) then (sim)
      :Registrar pagamento operacional;
      :Atualizar mensalidade;
      :Registrar Auditoria;
    else (não)
      :Encaminhar para perfil autorizado;
      :Registrar tentativa quando aplicável;
    endif
  else (não)
    :Prosseguir atendimento;
  endif

  if (Acesso solicitado?) then (sim)
    if (Regras permitem acesso?) then (sim)
      :Liberar acesso;
      :Registrar Auditoria/acesso;
    else (não)
      :Bloquear acesso com motivo;
      :Registrar Auditoria/acesso;
    endif
  endif

  :Finalizar atendimento;
else (não)
  :Solicitar novo login;
endif
stop
@enduml
