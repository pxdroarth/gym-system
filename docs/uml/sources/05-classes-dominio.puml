@startuml
title Modelo Conceitual de Domínio — Sistema Academia SA
hide methods
skinparam classAttributeIconSize 0
skinparam shadowing false

class Rede {
  +id
  +nome
  +status
}

class Unidade {
  +id
  +nome
  +tipo: Matriz/Filial
  +status
}

class UsuarioInterno {
  +id
  +nome
  +login/email
  +papel
  +status
}

class Aluno {
  +id
  +nome
  +status
  +dados cadastrais
}

class Plano {
  +id
  +nome
  +valor
  +status
}

class Mensalidade {
  +id
  +status
  +vencimento
  +valor
}

class Pagamento {
  +id
  +valor
  +data
  +snapshot histórico
}

class Produto {
  +id
  +nome
  +preço
  +estoque
}

class VendaProduto {
  +id
  +data
  +valor total
}

class ContaFinanceira {
  +id
  +tipo
  +valor
  +status
}

class PlanoContas {
  +id
  +categoria
  +tipo
}

class FechamentoMensal {
  +id
  +competência
  +status
}

class Acesso {
  +id
  +data/hora
  +resultado
  +motivo
}

class Vinculo {
  +id
  +tipo
  +status
}

class AuditLog {
  +id
  +ator
  +módulo
  +ação
  +metadata
}

class AuthSession {
  +id
  +token_hash
  +status
  +expires_at
}

class AuthRefreshToken {
  +id
  +family_id
  +token_hash
  +status
  +expires_at
}

Rede "1" o-- "1..*" Unidade
Rede "1" o-- "0..*" UsuarioInterno
Unidade "1" o-- "0..*" Aluno
UsuarioInterno "1" o-- "0..*" AuthSession
AuthSession "1" o-- "0..*" AuthRefreshToken
Aluno "1" o-- "0..*" Mensalidade
Plano "1" o-- "0..*" Mensalidade
Mensalidade "1" o-- "0..*" Pagamento
Aluno "1" o-- "0..*" Acesso
Aluno "1" o-- "0..*" Vinculo
Produto "1" o-- "0..*" VendaProduto
PlanoContas "1" o-- "0..*" ContaFinanceira
Unidade "1" o-- "0..*" FechamentoMensal
UsuarioInterno "1" o-- "0..*" AuditLog
@enduml
