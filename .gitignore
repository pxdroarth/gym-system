# =========================
# Dependências
# =========================
node_modules/
frontend/node_modules/
backend/node_modules/

# =========================
# Variáveis sensíveis
# =========================
.env
.env.*
!.env.example

frontend/.env
frontend/.env.*
!frontend/.env.example

backend/.env
backend/.env.*
!backend/.env.example

# =========================
# Build / cache
# =========================
dist/
build/
coverage/

frontend/dist/
frontend/build/
frontend/coverage/
frontend/.vite/

backend/dist/
backend/build/
backend/coverage/

.cache/
.parcel-cache/

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Banco local SQLite
# =========================
backend/*.sqlite
backend/*.sqlite-shm
backend/*.sqlite-wal

# =========================
# Sistema operacional / editor
# =========================
.DS_Store
Thumbs.db
Desktop.ini

.vscode/
.idea/

# =========================
# Arquivos temporários
# =========================
*.tmp
*.temp
*.bak
*.swp

# =========================
# Uploads locais opcionais
# Descomente se não quiser versionar
# =========================
