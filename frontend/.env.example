# Exemplo de ambiente do frontend - Sistema Academia SA
# Vite carrega variaveis VITE_* quando o arquivo .env esta na pasta frontend.
# Nao coloque segredos reais neste arquivo versionado.

# Opcional. URL base da API Express.
# Padrao no codigo quando ausente: http://localhost:3001
# Em producao, use a URL HTTPS publica da API.
VITE_API_URL=http://localhost:3001

# Desenvolvimento local apenas.
# Mantido falso por padrao para evitar login automatico acidental.
VITE_DEV_AUTO_LOGIN=false
VITE_DEV_LOGIN=LOGIN_LOCAL_DE_TESTE
VITE_DEV_PASSWORD=SENHA_LOCAL_DE_TESTE

# Opcionais. Ajustes do polyfill visual de confirmacao.
# Valores aceitos para VITE_CONFIRM_MODE: auto, sync, async, native
# Valores aceitos para VITE_CONFIRM_VARIANT: primary, warning, danger
VITE_CONFIRM_MODE=auto
VITE_CONFIRM_TITLE=Confirmacao
VITE_CONFIRM_MESSAGE=Tem certeza que deseja confirmar?
VITE_CONFIRM_OK=Confirmar
VITE_CONFIRM_CANCEL=Cancelar
VITE_CONFIRM_VARIANT=primary

# Opcional. Ordem da listagem de alunos.
# Valores esperados: asc ou desc
VITE_ALUNOS_ORDER=asc
